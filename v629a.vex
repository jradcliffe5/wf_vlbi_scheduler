*------------------------------------------------------------------------------
$GLOBAL;
     ref $EXPER = V629A;
*                                                      +------------+
*                         PI revision number:          |    3.0000  |
*                                                      +------------+
*------------------------------------------------------------------------------
$EXPER;
*
def V629A;
     exper_name = V629A;
     exper_description = "The EMU-VLBI pilot survey";
     PI_name = "Dr Jack Radcliffe";
     PI_email = jack.f.radcliffe@gmail.com;
*    address:   University of Pretoria
*               5-66, Natural Sciences 1
*               Lynwood Road, Hatfield, Pretoria, 0002
*               South Africa
*    phone:     +27734217237
*    during obs: 
*    fax:        
*               ATCA: Requesting single dish
*
*    year, doy: 2023, 309
*    date     : Sun  5 Nov 2023
*    MJD      : 60253
     exper_nominal_start=2023y309d06h00m00s;
     exper_nominal_stop=2023y310d02h00m00s;
*
     target_correlator = LBA;
*
*    integr_time    :     1.000 s
*    number_channels:    32
*    number_antenna :  5
*    cross_polarize : No
*    weight_func    : UNIFORM
*    distrib_medium : DAT
*    distrib_format : FITS
*    source_pos_cat : STANDARD
*    distribute_to  : 
*                     Jack Radcliffe
*               Requesting multi-phase centre correlation
*
enddef;
*------------------------------------------------------------------------------
$MODE;
*
def lba18cm-2p-2IF-64MHz;
     ref $PROCEDURES = Mode_01;
     ref $FREQ = 1636.00MHz4x64MHz:At:Pa;
     ref $FREQ = 1636.00MHz2x64MHz:Mp;
     ref $FREQ = 1652.00MHz16x16MHz:Cd;
     ref $FREQ = 1652.00MHz16x16MHz#02:Ho;
     ref $IF = LO@700MHzDPolNoTone:At;
     ref $IF = LO@1600MHzDPolNoTone:Pa;
     ref $IF = LO@1000MHzDPolNoTone:Mp;
     ref $IF = LO@2100MHzDPolNoTone:Cd;
     ref $IF = LO@1050MHzDPolNoTone:Ho;
     ref $BBC = 4BBCs:At:Pa;
     ref $BBC = 2BBCs:Mp;
     ref $BBC = 16BBCs:Cd;
     ref $BBC = 16BBCs#02:Ho;
     ref $TRACKS = LBA_.4Ch2bit1to1:At:Pa;
     ref $TRACKS = LBA_.2Ch2bit1to1:Mp;
     ref $TRACKS = MARK5B.16Ch2bit1to1:Cd;
     ref $TRACKS = MARK5B.16Ch2bit1to1#02:Ho;
     ref $HEAD_POS = LBAVoid:At:Pa:Mp;
*    ref $HEAD_POS = DiskVoid <= obsolete definition
     ref $ROLL = NoRoll:At:Pa:Mp:Cd:Ho;
     ref $PASS_ORDER = LBADummy:At:Pa:Mp;
*    ref $PASS_ORDER = DiskVoid <= obsolete definition
     ref $PHASE_CAL_DETECT = NoDetect:At:Pa;
     ref $PHASE_CAL_DETECT = NoDetect#02:Mp;
     ref $PHASE_CAL_DETECT = NoDetect#03:Cd:Ho;
enddef;
*------------------------------------------------------------------------------
$STATION;
*
def At;
     ref $SITE = ATCA;
     ref $ANTENNA = ATCA;
     ref $DAS = 1LBA+NONE<LBADR;
enddef;
*
def Pa;
     ref $SITE = PARKES;
     ref $ANTENNA = PARKES;
     ref $DAS = 1LBA+NONE<LBADR;
enddef;
*
def Mp;
     ref $SITE = MOPRA;
     ref $ANTENNA = MOPRA;
     ref $DAS = 1LBA+NONE<LBADR;
enddef;
*
def Cd;
     ref $SITE = CDDBBC;
     ref $ANTENNA = CDDBBC;
     ref $DAS = 1DBBC+NONE<;
enddef;
*
def Ho;
     ref $SITE = HOB_DBBC;
     ref $ANTENNA = HOB_DBBC;
     ref $DAS = 2DBBC+MARK5B<;
enddef;
*------------------------------------------------------------------------------
$PROCEDURES;
*
def Mode_01;
     procedure_name_prefix =  "01";
     tape_change =  420 sec;
     headstack_motion =    6 sec;
     new_source_command =    5 sec;
     new_tape_setup =   20 sec;
     setup_always = on :  20 sec;
     parity_check = off : 100 sec;
     tape_prepass = off : 600 sec;
     preob_cal  = on :  10 sec : preob;
     midob_cal  = on :  15 sec : midob;
     postob_cal = on :   0 sec : postob;
enddef;
*------------------------------------------------------------------------------
$SITE;
*
